{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "strict": true,
    "lib": ["ES2021", "DOM", "ESNext"],
    "types": ["jest", "node", "react", "react-dom"]
  },
  "include": [
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "web/src/**/*.ts",
    "web/src/**/*.tsx"
  ],
  "exclude": ["**/node_modules"]
}
