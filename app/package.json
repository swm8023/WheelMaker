{
  "name": "WheelMaker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:web": "npm run build:web:native && react-native run-android",
    "build:web": "webpack --config web/webpack.config.js --mode production",
    "build:web:release": "npm run build:web && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export_web_release.ps1",
    "build:web:native": "npm run build:web && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync_web_assets.ps1",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "tsc:web": "tsc -p web/tsconfig.web.json --noEmit",
    "web": "webpack serve --config web/webpack.config.js --mode development --hot",
    "web:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart_web.ps1 -Port 8080"
  },
  "dependencies": {
    "@codingame/monaco-vscode-theme-seti-default-extension": "^28.4.1",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@vscode/codicons": "^0.0.45",
    "react": "19.2.3",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.3",
    "react-native": "0.84.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-webview": "^13.16.1",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/community-cli-plugin": "^0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-test-renderer": "^19.1.0",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.2",
    "eslint": "^8.19.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
