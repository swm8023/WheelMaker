# 工具二进制（通过 server/scripts/install-tools.sh 下载）
server/bin/**/*
!server/bin/**/.gitkeep

# 运行时状态
.wheelmaker/
.tmp/
server/.tmp/
.tmp_codex_acc/
app/node_modules/

# Go build artifacts
*.exe
*.test
*.out
/vendor/
.gocache/
.gomodcache/
app/dist/
mobile/android/.gradle/
mobile/android/**/build/
mobile/android/local.properties
mobile/android/app/src/main/assets/
server/cmd/wheelmaker-desktop/webroot/*
!server/cmd/wheelmaker-desktop/webroot/.gitkeep
server/cmd/wheelmaker-desktop/desktop_windows.syso
server/cmd/wheelmaker-desktop/winres/*
!server/cmd/wheelmaker-desktop/winres/icon.png

# Runtime log files
wheelmaker_*.log
debug.log

# IDE
.vscode/
.idea/
*.swp

# RLCR loop state (humanize plugin)
.humanize*

# Local git worktrees
.worktrees/
