# 工具二进制（通过 server/scripts/install-tools.sh 下载）
server/bin/**/*
!server/bin/**/.gitkeep

# 运行时状态
.wheelmaker/

# Go build artifacts
*.exe
*.test
*.out
/vendor/
.gocache/
.gomodcache/
app/dist/

# Runtime log files
wheelmaker_*.log
debug.log

# IDE
.vscode/
.idea/
*.swp

# RLCR loop state (humanize plugin)
.humanize*

# Local git worktrees
.worktrees/
